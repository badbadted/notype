{
  "name": "notype",
  "version": "0.1.4",
  "description": "AI 語音輸入工具 — 用說的取代打字（Windows）",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/generate-icon.js",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable"
  },
  "author": "badbadted",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.2.0",
    "koffi": "^2.15.6",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.notype.app",
    "productName": "NoType",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["icon.png", "icon.ico"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "NoType"
    },
    "portable": {
      "artifactName": "NoType-Portable-${version}.exe"
    }
  }
}
